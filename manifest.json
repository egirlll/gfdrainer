{
  "manifest_version": 3,
  "name": "urscammergf's Auto-Drain",
  "version": "1.0",
  "description": "Auto-drain extension for urscammergf's Throne",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["https://throne.com/urscammergf/*"],
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    },
    "default_title": "urscammergf's Auto-Drain~"
  },
  "content_scripts": [
    {
      "matches": ["*://throne.com/urscammergf*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
